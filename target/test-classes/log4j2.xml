<?xml version="1.0" encoding="UTF-8"?>

<Configuration status="WARN">

    <Properties>

        <!-- Log Folder -->
        <Property name="log-path">logs</Property>

        <!-- Log Format -->
        <Property name="log-pattern">
            %d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %c{1}:%L - %msg%n
        </Property>

    </Properties>

    <Appenders>

        <!-- Console Logging -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${log-pattern}" />
        </Console>

        <!-- Rolling File Logging -->
        <RollingFile
                name="File"
                fileName="${log-path}/automation.log"
                filePattern="${log-path}/automation-%d{yyyy-MM-dd}-%i.log.gz">

            <PatternLayout pattern="${log-pattern}" />

            <Policies>

                <!-- Create new file every day -->
                <TimeBasedTriggeringPolicy interval="1"/>

                <!-- Create new file when size exceeds -->
                <SizeBasedTriggeringPolicy size="10 MB"/>

            </Policies>

            <!-- Keep last 30 archived files -->
            <DefaultRolloverStrategy max="30"/>

        </RollingFile>

    </Appenders>

    <Loggers>

        <!-- Reduce Selenium Internal Logs -->
        <Logger name="org.openqa.selenium" level="WARN" additivity="false">
            <AppenderRef ref="File"/>
        </Logger>

        <!-- Reduce Apache HTTP Logs -->
        <Logger name="org.apache.http" level="WARN" additivity="false">
            <AppenderRef ref="File"/>
        </Logger>

        <!-- Reduce WebDriverManager Logs -->
        <Logger name="io.github.bonigarcia" level="WARN" additivity="false">
            <AppenderRef ref="File"/>
        </Logger>

        <!-- Framework Logs -->
        <Root level="INFO">

            <AppenderRef ref="Console"/>

            <AppenderRef ref="File"/>

        </Root>

    </Loggers>

</Configuration>